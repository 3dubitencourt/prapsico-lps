# ==========================================================
# PRAPSICO LPs — Variáveis de ambiente
# ==========================================================
# Copie este arquivo pra .env.local (desenvolvimento) e pra
# Vercel → Project Settings → Environment Variables (produção)
# ==========================================================

# ----------------------------------------------------------
# 1) KOMMO CRM — API v4 (recomendado)
# ----------------------------------------------------------
# Como criar:
#   1. Kommo → Configurações → Integrações → "+ CRIAR INTEGRAÇÃO"
#   2. Tipo: "Integração privada" / "Private integration"
#   3. Nome: "Prapsico LPs"
#   4. Scopes: CRM (leads, contacts, custom fields, notes)
#   5. Salvar → copiar o "Token de acesso de longa duração"
#
# Subdomínio = o que vem antes de .kommo.com na URL (ex: "psicoeducacao").
KOMMO_SUBDOMAIN=psicoeducacao
KOMMO_ACCESS_TOKEN=

# ----------------------------------------------------------
# 1b) CRM via webhook genérico (alternativa/legacy)
# ----------------------------------------------------------
# Se preferir mandar via Make/n8n/Zapier no lugar da API direta.
# Pode deixar vazio se estiver usando KOMMO_ACCESS_TOKEN acima.
CRM_WEBHOOK_URL=

# ----------------------------------------------------------
# 2) WHATSAPP — notificação do TIME da Prapsico (você)
# ----------------------------------------------------------
# Toda vez que um lead se cadastra, você recebe um WhatsApp.
# Pode usar: Z-API, Evolution API, Make.com, n8n, Zapier.
# A URL recebe POST com {phone, message}.
# Se Kommo já notifica via integração WhatsApp, pode deixar vazio.
WHATSAPP_NOTIFY_URL=

# Número que recebe a notificação (sem +, só dígitos).
# Default: 5535992571045 (Prapsico). Sobrescreva se mudar.
SALES_WHATSAPP_NUMBER=5535992571045

# ----------------------------------------------------------
# 3) WHATSAPP automático PRO LEAD (formulários qualificados)
# ----------------------------------------------------------
# Quando o lead manda /inscricao-cert ou /inscricao-pos, ele
# recebe uma mensagem automática de boas-vindas no WhatsApp.
# Mesmo formato: POST {phone, message}.
WHATSAPP_AUTOMSG_WEBHOOK_URL=

# ----------------------------------------------------------
# 4) NOTIFICAÇÕES ADICIONAIS (opcionais)
# ----------------------------------------------------------
# Slack — webhook de entrada num canal
SLACK_LEADS_WEBHOOK_URL=
SLACK_COORDENACAO_WEBHOOK_URL=

# Telegram — bot token + chat ID
TELEGRAM_BOT_TOKEN=
TELEGRAM_LEADS_CHAT_ID=
TELEGRAM_COORDENACAO_CHAT_ID=

# ----------------------------------------------------------
# 5) TRACKING
# ----------------------------------------------------------
# GTM container ID (memória: GTM-PRHTN3VV é o oficial)
NEXT_PUBLIC_GTM_ID=GTM-PRHTN3VV
